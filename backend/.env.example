PORT=3001
FRONTEND_URL=http://localhost:5173

# Veritabanı modu:
#   true  → Firebase bağlantısı olmadan bellek içi çalışır (hızlı test)
#   false → Firebase Firestore kullanılır (aşağıdaki bilgileri doldurun)
DB_USE_MEMORY=false

# JWT
JWT_SECRET=cok-gizli-jwt-anahtariniz-buraya-yazin
JWT_EXPIRES_IN=8h

# ─── Firebase / Firestore ──────────────────────────────────────────────────
# Firebase Console → Proje Ayarları → Hizmet Hesapları → Yeni özel anahtar oluştur
# İndirilen JSON dosyasından şu üç değeri kopyalayın:
FIREBASE_PROJECT_ID=proje-id-buraya
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@proje-id.iam.gserviceaccount.com
# private_key değerini tek satır olarak yapıştırın (kaçış karakterleri korunmalı):
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMII...\n-----END RSA PRIVATE KEY-----\n"

# RabbitMQ — yoksa EventEmitter fallback'e geçer (local dev)
# RABBITMQ_URL=amqp://guest:guest@localhost:5672
